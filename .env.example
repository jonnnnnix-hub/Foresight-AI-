# FlowEdge Paper Trading Bots — Environment Variables
# Copy to .env and fill in your values.
# For Fly.io: set these via fly secrets set KEY=value

# ── Market Data ──────────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key

# ── Account 1: Scalp v2 + Volume Scalper v1 ─────────────────────
ALPACA_API_KEY_ID=your_alpaca_paper_key_id
ALPACA_API_SECRET_KEY=your_alpaca_paper_secret_key

# ── Account 2: Production Scanner (precision/hybrid/rapid) ──────
ALPACA_PROD_KEY_ID=your_alpaca_prod_paper_key_id
ALPACA_PROD_SECRET_KEY=your_alpaca_prod_paper_secret_key

# ── Account 3: Trident ETF 0DTE Scalper ─────────────────────────
TRIDENT_ALPACA_KEY_ID=your_trident_alpaca_key_id
TRIDENT_ALPACA_SECRET_KEY=your_trident_alpaca_secret_key

# ── Email Alerts (optional — bots work without these) ───────────
ALERT_EMAIL_TO=your_email@gmail.com
ALERT_EMAIL_FROM=your_email@gmail.com
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=your_email@gmail.com
ALERT_SMTP_PASS=your_gmail_app_password

# ── S3 Data (for backtest data downloads — not needed for live) ──
MASSIVE_ACCESS_KEY=your_massive_s3_key
MASSIVE_SECRET_KEY=your_massive_s3_secret
